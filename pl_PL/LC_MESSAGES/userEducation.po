msgid "UE_BETTER_CATEGORIES_CONTENT"
msgstr "Browse your favorite <strong>categories and channels</strong> right here. Like Flipnote Hatena, <strong>channels now have icons</strong>, too."

# Feature 5: Better Channels/Categories
msgid "UE_BETTER_CATEGORIES_TITLE"
msgstr "Better Channels and Categories!"

msgid "UE_COMMENT_REPLIES_CONTENT"
msgstr "Avid commenters rejoice! You can now <strong>reply to comments directly</strong> from your console or on the web."

# Feature 6: Comment replies
msgid "UE_COMMENT_REPLIES_TITLE"
msgstr "Re: re: re: re: re:"

msgid "UE_CONSOLE_MANAGEMENT_CONTENT"
msgstr "With Console Management, you can now have multiple consoles linked to your Sudomemo account!"

# Feature: Console Management
msgid "UE_CONSOLE_MANAGEMENT_TITLE"
msgstr "Double Life"

msgid "UE_FINISH"
msgstr "Let's Go!"

msgid "UE_FLIPNOTE_EXPORT_CONTENT"
msgstr "You can now <strong>download your Flipnotes</strong> as an <strong>MP4, GIF, or PPM</strong> straight from the web. How convenient!"

msgid "UE_FLIPNOTE_EXPORT_TITLE"
msgstr "Share in more places!"

msgid "UE_FLIPNOTE_GENEALOGY_CONTENT"
msgstr "With <strong>Flipnote Genealogy</strong>, you can now see the entire <strong>spin-off tree</strong> of any Flipnote."

# Feature 3: Flipnote Genealogy (How did we get here?)
msgid "UE_FLIPNOTE_GENEALOGY_TITLE"
msgstr "How did we get here?"

msgid "UE_FLIPNOTE_ORGANIZER_CONTENT"
msgstr "You can now organize how your Flipnotes appear on Flipnote Studio with the <strong>Flipnote Organizer</strong>! Just upload your Flipnote folder, press E, and organize away! Check out the help article in our help center to learn more."

msgid "UE_FLIPNOTE_ORGANIZER_TITLE"
msgstr "Wow, how organized!"

msgid "UE_FOLLOWING_LIST_CONTENT"
msgstr "Want to see your <strong>full following and followers list</strong>?<br>You're in luck, because now you can!"

# Feature 1: Following List (@everyone)
msgid "UE_FOLLOWING_LIST_TITLE"
msgstr "@everyone"

msgid "UE_INTRO_MESSAGE"
msgstr "Let's flip through what's new!"

msgid "UE_LOGIN_MANAGER_CONTENT"
msgstr "Dreamed of being able to quickly switch between your accounts on the web? Now that dream is a reality with the new <strong>Login Manager</strong>!"

msgid "UE_LOGIN_MANAGER_TITLE"
msgstr "Why yes, I do have 5 DSis"

msgid "UE_MEMO_PLUS_CONTENT"
msgstr "Introducing Memo+, a color enhancement feature for Flipnotes! It allows you to replace the default Flipnote colors and add visual effects when your Flipnote is viewed on Sudomemo Theatre."

# Feature: Memo+
msgid "UE_MEMO_PLUS_TITLE"
msgstr "See It in Color!"

msgid "UE_NEW_DAILY_DRAW_CONTENT"
msgstr "Remember the Sudomemo Daily Draw? Reminisce no more, because it's back! Check out the Daily Draw channel and draw away!"

msgid "UE_NEW_DAILY_DRAW_TITLE"
msgstr "It's been 84 years..."

# Control buttons
msgid "UE_NEXT"
msgstr "Next"

msgid "UE_NOTIFICATIONS_CONTENT"
msgstr "<strong>Notifications</strong> are now <strong>synced from your console</strong>.<br>Now you can always stay up-to-date!"

# Feature 4: Notifications (Extra! Extra!)
msgid "UE_NOTIFICATIONS_TITLE"
msgstr "Extra! Extra!"

msgid "UE_PROFILE_PICTURE_CONTENT"
msgstr "You can now <strong>change your profile picture on Sudomemo Theatre</strong>. Click \"Edit Flipnote\" and apply!"

# Feature 2: Profile Picture (Looking good!)
msgid "UE_PROFILE_PICTURE_TITLE"
msgstr "Looking good!"

msgid "UE_PROFILE_SHELVES_CONTENT"
msgstr "Customize your Creator's Room with shelves! Show off your best Flipnotes or an entire playlist with ease."

msgid "UE_PROFILE_SHELVES_TITLE"
msgstr "Easier than Ikea!"

msgid "UE_SKIP_ALL"
msgstr "Skip All"

msgid "UE_WEB_INVENTORY_CONTENT"
msgstr "You can now manage tickets, items, and themes on Sudomemo Theatre with Web Inventory. You might even find a surprise or two in your inventory that you didn't know about!"

# Feature: Web Inventory
msgid "UE_WEB_INVENTORY_TITLE"
msgstr "So Many Things..."

msgid "UE_WELCOME_BACK_SUBTITLE"
msgstr "A lot has changed since you've last logged on."

msgid "UE_WELCOME_BACK_SUBTITLE_FEW"
msgstr "Some things have changed since you've last logged on."

# Welcome slide
msgid "UE_WELCOME_BACK_TITLE"
msgstr "Welcome back!"

msgid "UE_YOUTUBE_PLAYLISTS_CONTENT"
msgstr "<strong>YouTube uploading</strong> just got a whole lot better! You can now select which <strong>playlists</strong> you want to add your uploaded Flipnotes to, plus, you can also change the <strong>visibility settings</strong> when uploading from Sudomemo on the DS."

msgid "UE_YOUTUBE_PLAYLISTS_TITLE"
msgstr "Time to go viral"
