# IMPORTANT NOTE ABOUT TRANSLATING THIS FILE
# Pay close attention to "Only translate" as this includes the usage statements for our public Discord bot.
# Spaces at the beginning must be kept intact. There are three spaces before each command entry
# and six spaces before each command usage note.
# \n represents a newline (aka a line break). Leave these alone as well.
msgid ""
msgstr ""
"Language: es_ES\n"
"Content-Type: text/plain; charset=UTF-8\n"

# Username was given a Nitro Booster Ticket...
msgid "BOOST_TICKET_SUCCESS"
msgstr "%s recibió un ticket de Nitro Booster, canjeable por un mes de Sudomemo Plus y un trofeo especial. ¡Hurra!"

msgid "CONSIDER_X_CHANNEL_FOR_THIS"
msgstr "Tal vez %s podría ser mejor para hacer esto"

# Account linking
msgid "DISCORD_LINKING_GET_STARTED"
msgstr "Por favor, ¡Entra a %s para empezar!"

msgid "DISCORD_LINKING_REQUIRED"
msgstr "Deberás enlazar tu cuenta de Sudomemo para hacer eso."

msgid "DISCORD_LINKING_SUCCESS"
msgstr "¡Se ha enlazado tu cuenta correctamente!"

msgid "DISCORD_LINKING_UNLINKED"
msgstr "Se ha eliminado el enlace entre tu cuenta de Discord y Sudomemo."

msgid "DISCORD_LINKING_UNLINK_NOT_LINKED_YET"
msgstr "Tu cuenta de Discord no está enlazada a una cuenta de Sudomemo."

# "Invalid mode - must be one of: song, artist, genre"
msgid "MUSICMATCH_INVALID_MODE"
msgstr "Modo inválido - debe ser uno de %s"

msgid "MUSICMATCH_MOVIE_COUNT_PLURAL"
msgstr "%d Flipnotes"

msgid "MUSICMATCH_MOVIE_COUNT_SINGULAR"
msgstr "%d Flipnote"

msgid "MUSICMATCH_NO_RESULTS"
msgstr "No encontré nada para eso, ¡perdón!"

msgid "MUSICMATCH_RESULT_HEADER_GT_MAX"
msgstr "Los %d primeros resultados:"

msgid "MUSICMATCH_RESULT_HEADER_LT_MAX"
msgstr "%d resultado(s):"

# SongName by BandName
msgid "MUSICMATCH_TITLE_BY_ARTIST"
msgstr "%s por %s"

msgid "PATRON_TICKET_SUCCESS"
msgstr "¡Recibiste un Ticket de Patrón de Sudomemo %s!"

msgid "REJECT_ACCOUNT_ALREADY_LINKED"
msgstr "¡Tu cuenta de Sudomemo ya está enlazada!"

msgid "REJECT_BOOST_TICKET_COOLDOWN"
msgstr "¡Ya regalaste un ticket de Nitro Booster este mes! (%s)"

msgid "REJECT_FSID_ENOENT"
msgstr "No pude encontrar un usuario con ese ID de Flipnote Studio en Sudomemo."

msgid "REJECT_GENERIC_ERROR"
msgstr "Me encontré con un problema al intentar hacer eso. ¡Perdón!"

msgid "REJECT_INVALID_FSID"
msgstr "¡Eso no es un ID de Flipnote Studio válido!"

msgid "REJECT_INVALID_LINK_TOKEN"
msgstr "¡Eso no es un token de vinculación válido! Por favor, ¡visita %s para comenzar!"

msgid "REJECT_LINK_TOKEN_ENOENT"
msgstr "Este token de vinculación caducó o ya no existe."

msgid "REJECT_NOT_NITRO_BOOSTER"
msgstr "¡Necesitas ser un Sudomemo Nitro Booster para usar esto!"

msgid "REJECT_NOT_PATRON"
msgstr "¡Necesitas ser un Patrón de Sudomemo para usar esto!"

msgid "REJECT_PATRON_TICKET_COOLDOWN"
msgstr "¡Ya reclamaste tu ticket de Patrón este mes!"

msgid "REJECT_USER_ENOENT"
msgstr "No encontré a ese usuario en Sudomemo."

# displayed as "💡 Link your Sudomemo account with `.sudo link`"
msgid "UNLINKED_COMMAND_TIP"
msgstr "Enlaza tu cuenta de Sudomemo con"

# "Usage: example_command <fsid>"
msgid "USAGE"
msgstr "Uso"

# ONLY TRANSLATE: "usage", "commands"
msgid "USAGE_INTRO"
msgstr ""
"uso: .sudo ...\n"
"\n"
"comandos:"

msgid "USAGE_draw"
msgstr ""
"   draw\n"
"      ¡Saca un Ticket Normal y mira si ganas un premio!"

msgid "USAGE_link"
msgstr ""
"   link\n"
"      Enlaza tu cuenta de Sudomemo a Discord"

# ONLY TRANSLATE "Search Sudomemo MusicMatch" and "What you're searching for"
msgid "USAGE_musicmatch"
msgstr ""
"   mm, musicmatch <mode> <query>\n"
"      Buscar Sudomemo MusicMatch\n"
"      <mode>: song, artist, genre\n"
"      <query>: Lo que estas buscando"

# ONLY TRANSLATE: "Give Nitro Booster ticket..." and "Flipnote Studio ID"
msgid "USAGE_nitro_plus"
msgstr ""
"   nitro_plus <FSID|self>\n"
"      Regalar ticket de Nitro Booster (1 mes de Sudomemo Plus y un trofeo).\n"
"      <FSID>: ID de Flipnote Studio"

msgid "USAGE_patron_plus"
msgstr ""
"   patron_plus\n"
"      Reclamar Ticket mensual de Patrón"

