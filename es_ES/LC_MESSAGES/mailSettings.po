msgid "DISABLE"
msgstr "Desactivar"

msgid "DISABLED"
msgstr "Desactivado"

msgid "DISABLE_CONFIRMATION_FORMAT"
msgstr "¿Estás seguro de que quieres desactivar los correos de '%s'?"

msgid "EMAIL_CHANGE_TOKEN_EXPIRED"
msgstr "El link al que entraste ha caducado."

msgid "EMAIL_SETTING_DISABLED_FINISH_FORMAT"
msgstr "Has desactivado los correos de '%s'."

msgid "ENABLE"
msgstr "Activar"

msgid "ENABLED"
msgstr "Activado"

msgid "HEADER_CHANGE_EMAIL_SETTINGS"
msgstr "Cambiar Ajustes de Correo"

msgid "HEADER_MAIL_SETTINGS"
msgstr "Ajustes de Correo"

msgid "LOGIN_REQUIRED_TO_VIEW_PAGE"
msgstr "Debes haber iniciado sesión para editar tus Ajustes de Correo."

msgid "MAIL_STATUS"
msgstr "Estado"

msgid "MAIL_TYPE"
msgstr "Tipo"

msgid "REENABLE_INSTRUCTIONS"
msgstr "Si quieres volver a habilitarlos, puedes hacerlo seleccionando <strong>Ajustes de Correo</strong> en tu Sala del Creador."

msgid "TAP_ON_STATUS_TO_VIEW_DETAILS"
msgstr "Toca en el estado actual de un tipo de correo para cambiar su estado o ver una descripción más detallada."

msgid "TAP_TO_DISABLE"
msgstr "Presiona para deshabilitar"

msgid "TAP_TO_ENABLE"
msgstr "Presiona para habilitar"

msgid "TYPE_COMMENT_NOTIF_DESC"
msgstr "Recibe un correo electrónico cuando alguien comente en uno de tus Flipnotes."

msgid "TYPE_COMMENT_NOTIF_NAME"
msgstr "Comentario Recibido"

msgid "TYPE_DIGEST_DESC"
msgstr "Correo periódico con un resumen que incluye nuevos Flipnotes de tus favoritos, Estrellas recibidas, comentarios recibidos, nuevos seguidores, entre otros."

msgid "TYPE_DIGEST_NAME"
msgstr "Correos de Resumen"

msgid "TYPE_FAVE_NOTIF_DESC"
msgstr "Recibe un correo electrónico cuando alguien te añada a sus Favoritos."

msgid "TYPE_FAVE_NOTIF_NAME"
msgstr "Añadido como Favorito"

msgid "TYPE_METADATA_NOTICE_DESC"
msgstr "Recibe un correo cuando detectemos problemas con los metadatos de tu Flipnote."

msgid "TYPE_METADATA_NOTICE_NAME"
msgstr "Aviso sobre Metadatos Faltantes"

msgid "TYPE_NEWS_DESC"
msgstr "Recibe un correo electrónico cuando algo nuevo sea publicado en las Noticias de Sudomemo."

msgid "TYPE_NEWS_NAME"
msgstr "Noticias de Sudomemo"

msgid "TYPE_PROMO_DESC"
msgstr "¡Recibe correos electrónicos sobre nuevas funciones, consejos y eventos que están por venir!"

msgid "TYPE_PROMO_NAME"
msgstr "Promoción"

msgid "TYPE_REPORT_UPDATE_DESC"
msgstr "Recibe un correo cuando cambiemos el estado de contenido que hayas reportado."

msgid "TYPE_REPORT_UPDATE_NAME"
msgstr "Actualización de Contenido Reportado"

msgid "TYPE_SECURITY_NOTIF_DESC"
msgstr "Recibe un correo cuando se cambie tu dirección de correo electrónico y/o contraseña."

msgid "TYPE_SECURITY_NOTIF_NAME"
msgstr "Seguridad de la Cuenta"

msgid "TYPE_SERVICE_UPDATE_DESC"
msgstr "Actualizaciones importantes sobre el estado o disponibilidad de Sudomemo relacionadas con tu cuenta."

msgid "TYPE_SERVICE_UPDATE_NAME"
msgstr "Actualizaciones de Servicio"

msgid "TYPE_SPINOFF_NOTIF_DESC"
msgstr "Recibe un correo electrónico cuando alguien suba un spin-off de alguno de tus Flipnotes."

msgid "TYPE_SPINOFF_NOTIF_NAME"
msgstr "Spin-off Recibido"

msgid "TYPE_STAR_REPORT_DESC"
msgstr "Recibe un correo electrónico al final del día acerca de las estrellas recibidas."

msgid "TYPE_STAR_REPORT_NAME"
msgstr "Reporte Diario de Estrellas"

msgid "TYPE_UNREAD_COMMENTS_DESC"
msgstr "Recibe un resumen por correo de todos los comentarios nuevos que hayas recibido recientemente."

msgid "TYPE_UNREAD_COMMENTS_NAME"
msgstr "Comentarios no leídos"
